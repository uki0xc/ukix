#!name=eplayerx
#!desc=eplayerx会员破解

[Script]
eplayerx-request = type=http-request, pattern=https:\/\/api\.(revenuecat|rc-backup)\.com\/v1\/(subscribers|receipts), script-path=https://raw.githubusercontent.com/uki0xc/ukix/refs/heads/beta/js/eplayerx.js, timeout=60
eplayerx-response = type=http-response, pattern=https:\/\/api\.(revenuecat|rc-backup)\.com\/v1\/(subscribers|receipts), script-path=https://raw.githubusercontent.com/uki0xc/ukix/refs/heads/beta/js/eplayerx.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% api.revenuecat.com, api.rc-backup.com
