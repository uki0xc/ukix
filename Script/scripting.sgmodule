#!name=Scripting RevenueCat Detector
#!desc=Log RevenueCat request and response metadata for com.scripting.ios without modifying payloads.

[Script]
scripting-rc-request = type=http-request, pattern=https:\/\/api\.(revenuecat|rc-backup)\.com\/v1\/, script-path=https://raw.githubusercontent.com/uki0xc/ukix/refs/heads/main/js/scripting.js, timeout=60
scripting-rc-response = type=http-response, pattern=https:\/\/api\.(revenuecat|rc-backup)\.com\/v1\/, script-path=https://raw.githubusercontent.com/uki0xc/ukix/refs/heads/main/js/scripting.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% api.revenuecat.com, api.rc-backup.com
